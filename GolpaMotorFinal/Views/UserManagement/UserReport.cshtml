@{
    Layout = "_AdminLayout";
}

<div class="container-fluid py-3" dir="rtl">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="fw-bold mb-1">گزارش‌ها و تحلیل‌ها</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a href="#" class="text-decoration-none">خانه</a>
                    </li>
                    <li class="breadcrumb-item active">
                        گزارش‌ها و تحلیل‌ها
                    </li>
                </ol>
            </nav>
        </div>
    </div>
    <!-- Filters Card -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
            <div class="d-flex justify-content-between align-items-center">
                <button class="btn btn-sm btn-link text-decoration-none"
                        data-bs-toggle="collapse"
                        data-bs-target="#filtersSection">
                    <i class="fa fa-chevron-up"></i>
                </button>
                <div class="fw-bold">
                    فیلترها
                    <i class="fa fa-funnel-dollar me-1"></i>
                </div>
            </div>
        </div>
        <div class="collapse show" id="filtersSection">
            <div class="card-body">
                <div class="row g-3">

                    <!-- Province -->
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label">استان و شهر</label>
                        <select class="form-select">
                            <option>همه استان‌ها</option>
                            <option>تهران</option>
                            <option>اصفهان</option>
                            <option>فارس</option>
                        </select>
                    </div>

                    <!-- Job -->
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label">شغل</label>
                        <select class="form-select">
                            <option>همه مشاغل</option>
                        </select>
                    </div>

                    <!-- Date Range -->
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label">بازه زمانی (از)</label>
                        <input type="date" class="form-control">
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label">بازه زمانی (تا)</label>
                        <input type="date" class="form-control">
                    </div>

                    <!-- Score Range -->
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label">امتیاز کل از</label>
                        <input type="number" class="form-control">
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label">امتیاز کل تا</label>
                        <input type="number" class="form-control">
                    </div>

                    <!-- Redeemed Score -->
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label">امتیاز مصرف شده از</label>
                        <input type="number" class="form-control">
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="form-label">امتیاز مصرف شده تا</label>
                        <input type="number" class="form-control">
                    </div>

                    <!-- Buttons -->
                    <div class="col-12">
                        <div class="d-flex flex-wrap gap-2 justify-content-end">
                            <button class="btn btn-outline-secondary">
                                <i class="fa fa-arrow-clockwise"></i>
                                پاک کردن فیلترها
                            </button>
                            <button class="btn btn-primary">
                                <i class="fa fa-search"></i>
                                اعمال فیلترها
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-3">

                <div class="d-flex gap-2">

                    <button class="btn btn-outline-success">
                        <i class="bi bi-file-earmark-excel"></i>
                        خروجی اکسل
                    </button>

                    <button class="btn btn-outline-primary">
                        <i class="bi bi-columns-gap"></i>
                        ستون‌ها
                    </button>

                </div>

                <div class="text-muted">
                    تعداد نتایج:
                    <strong class="text-primary">1,248</strong>
                </div>

            </div>

            <!-- Responsive Table -->
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle text-nowrap">
                    <thead class="table-dark">
                        <tr>
                            <th>ردیف</th>
                            <th>نام مشتری</th>
                            <th>شماره موبایل</th>
                            <th>استان</th>
                            <th>شهر</th>
                            <th>امتیاز کل</th>
                            <th>امتیاز مصرف شده</th>
                            <th>مانده امتیاز</th>
                            <th>تاریخ عضویت</th>
                            <th>آخرین تراکنش</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 1; i <= 8; i++)
                        {
                            <tr>
                                <td>@i</td>
                                <td>مهدی کریمی</td>
                                <td>09123456789</td>
                                <td>تهران</td>
                                <td>تهران</td>
                                <td>125,000</td>
                                <td>25,000</td>
                                <td class="text-success fw-bold">100,000</td>
                                <td>1402/01/15</td>
                                <td>1403/02/28</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Footer -->
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-3 gap-3">

                <!-- Pagination -->
                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item disabled">
                            <a class="page-link">«</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link">1</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link">2</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link">3</a>
                        </li>
                        <li class="page-item active">
                            <a class="page-link">4</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link">»</a>
                        </li>
                    </ul>
                </nav>

                <!-- Page Size -->
                <div class="d-flex align-items-center gap-2">
                    <span>تعداد در صفحه</span>
                    <select class="form-select form-select-sm" style="width:auto;">
                        <option>10</option>
                        <option selected>20</option>
                        <option>50</option>
                        <option>100</option>
                    </select>
                </div>
            </div>
        </div>
    </div>
</div>





