@model DomainModel.ViewModels.User.UserDetailsModel
@using GolpaMotorFinal.Helpers

<div class="row">

    <div class="col-md-4 text-center">

        <img src="@ImageHelper.Fix(Model.ProfileImageUrl)"
             class="img-fluid img-thumbnail rounded"
             alt="@($"{Model.FirstName} {Model.LastName}")" />

        <h5 class="mt-3">
            @Model.FirstName @Model.LastName
        </h5>

        <p class="text-muted">
            @Model.RoleName
        </p>

        @if (Model.IsActive)
        {
            <span class="badge bg-success">فعال</span>
        }
        else
        {
            <span class="badge bg-danger">غیرفعال</span>
        }

    </div>

    <div class="col-md-8">

        <table class="table table-bordered ">

            <tbody>

                <tr>
                    <th width="35%">شناسه کاربر</th>
                    <td>@Model.UserID</td>
                </tr>

                <tr>
                    <th>نام</th>
                    <td>@Model.FirstName</td>
                </tr>

                <tr>
                    <th>نام خانوادگی</th>
                    <td>@Model.LastName</td>
                </tr>

                <tr>
                    <th>شماره موبایل</th>
                    <td>@Model.PhoneNumber</td>
                </tr>

                <tr>
                    <th>ایمیل</th>
                    <td>@Model.Email</td>
                </tr>

                <tr>
                    <th>استان</th>
                    <td>@Model.Province</td>
                </tr>

                <tr>
                    <th>شهر</th>
                    <td>@Model.City</td>
                </tr>

                <tr>
                    <th>آدرس</th>
                    <td>@Model.Address</td>
                </tr>

                <tr>
                    <th>کد پستی</th>
                    <td>@Model.PostalCode</td>
                </tr>

                <tr>
                    <th>تاریخ ثبت نام</th>
                    <td>@Model.RegisterDate.ToString("yyyy/MM/dd")</td>
                </tr>

                <tr>
                    <th>شماره کارت</th>
                    <td>@Model.CreditCartNumber</td>
                </tr>

                <tr>
                    <th>شماره شبا</th>
                    <td>@Model.IBAN</td>
                </tr>

                <tr>
                    <th>شماره حساب</th>
                    <td>@Model.AccountNumber</td>
                </tr>

            </tbody>

        </table>

    </div>

</div>

<hr />

<h5 class="mb-3">
    اطلاعات امتیازات
</h5>

<div class="row">

    <div class="col-md-3">
        <div class="card border-success">
            <div class="card-body text-center">
                <h6>امتیاز کل</h6>
                <h4 class="text-success">
                    @Model.TotalEarnedPoints
                </h4>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-warning">
            <div class="card-body text-center">
                <h6>امتیاز مصرف شده</h6>
                <h4 class="text-warning">
                    @Model.TotalSettledPoints
                </h4>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-primary">
            <div class="card-body text-center">
                <h6>مانده امتیاز</h6>
                <h4 class="text-primary">
                    @Model.RemainedPoints
                </h4>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-info">
            <div class="card-body text-center">
                <h6>کارت‌های ثبت شده</h6>
                <h4 class="text-info">
                    @Model.TotalRegisteredCards
                </h4>
            </div>
        </div>
    </div>

</div>