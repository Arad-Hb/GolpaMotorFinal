 @{
    Layout = "_AdminLayout";
}

<div class="row justify-content-center">
    <div class="col-12 col-xl-11">
        <div class="merge-account-page">
    <div class="card">
        <!-- Header -->
        <div class="card-header justify-content-center bg-white border-bottom">
            <div class="d-flex align-items-center">
                <h2 class="mb-0 fw-bold" style="color:#04264e">ادغام حساب‌های کاربری</h2>
            </div>
        </div>
        <div class="card-body">
            <!-- Main Account -->
            <h5 class="text-primary mb-3">حساب اصلی</h5>
            <div class="card mb-4">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <div class="merge-avatar merge-avatar-primary">
                                <i class="fa fa-user"></i>
                            </div>
                        </div>
                        <div class="col">
                            <div class="row gy-2">
                                <div class="col-12">
                                    <span class="text-muted">نام:</span>
                                    <strong>علی رضایی</strong>
                                </div>
                                <div class="col-12">
                                    <span class="text-muted">شماره موبایل:</span>
                                    <strong>09123456789</strong>
                                </div>
                                <div class="col-12">
                                    <span class="text-muted">امتیاز:</span>
                                    <strong class="text-primary fs-5">
                                        25,000
                                    </strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Search Number -->
            <div class="mb-4">
                <label class="form-label fw-semibold">
                    افزودن شماره جدید
                </label>
                @await Component.InvokeAsync("SearchBox",
                     new
                     {
                         placeholderText = "جستجوی کاربران...",
                         actionName = "Search",
                         controllerName = "UserManagement"
                     })
            </div>

            <!-- Found Accounts -->
            <h4 class="mb-3">حساب(های) یافت شده</h4>
            <div class="card mb-4">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                           <div class="merge-avatar merge-avatar-success">
                               <i class="fa fa-user"></i>
                           </div>
                        </div>
                        <div class="col">
                            <div class="row gy-2">
                                <div class="col-12">
                                    <span class="text-muted">نام:</span>
                                    <strong>علی رضایی</strong>
                                </div>
                                <div class="col-12">
                                    <span class="text-muted">شماره موبایل:</span>
                                    <strong>09351234567</strong>
                                </div>
                                <div class="col-12">
                                    <span class="text-muted">امتیاز:</span>
                                    <strong class="text-primary fs-5">
                                        20,000
                                    </strong>
                                </div>
                            </div>
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-outline-danger">
                                <i class="fa fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Result -->
            <div class="alert alert-success mb-4">
                <div class="row align-items-center text-center">
                    <div class="col-12 col-md-auto mb-3 mb-md-0">
                        <i class="fa fa-award fs-1 " style="color:goldenrod"></i>
                    </div>
                    <div class="col">
                        <div class="fw-bold mb-2">
                            مجموع امتیازات پس از ادغام
                        </div>
                        <div class="d-flex justify-content-center align-items-center gap-3 fs-3 fw-bold flex-wrap">
                            <span>25,000</span>
                            <span>+</span>
                            <span>20,000</span>
                            <span>=</span>
                            <span class="display-6 text-success mb-0">
                                45,000
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="row g-2">
                <div class="col-12 col-md-6">
                    <button class="merge-confirm-btn w-100">
                        تاییدادغام
                    </button>
                </div>
                <div class="col-12 col-md-6 ">
                    <button class="merge-cancel-btn w-100">
                        انصراف
                    </button>
                </div>
            </div>
        </div>
    </div>
    </div>
</div>
</div>


