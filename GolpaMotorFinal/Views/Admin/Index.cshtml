@{
    ViewData["Title"] = "داشبورد";
    Layout = "_AdminLayout";
}

<div class="mb-4">

    <div class="page-title">
        داشبورد مدیریت گارانتی
    </div>

    <div class="page-subtitle">
        وضعیت کلی فروشگاه لوازم یدکی
    </div>

</div>

<div class="row g-4 mb-4">

    <div class="col-xl-3 col-md-6">
        <div class="card dashboard-card">
            <div class="card-body">
                <div class="stat-icon bg-success">
                    <i class="fa-solid fa-shield-halved"></i>
                </div>
                <h3>12,548</h3>
                <p>گارانتی ثبت شده</p>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card dashboard-card">
            <div class="card-body">

                <div class="stat-icon bg-warning">
                    <i class="fa-solid fa-clock"></i>
                </div>

                <h3>1,420</h3>

                <p>گارانتی باقی مانده</p>

            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card dashboard-card">
            <div class="card-body">

                <div class="stat-icon bg-danger">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>

                <h3>325</h3>

                <p>محصول بدون گارانتی</p>

            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card dashboard-card">
            <div class="card-body">

                <div class="stat-icon bg-purple">
                    <i class="fa-solid fa-gift"></i>
                </div>

                <h3>2,850</h3>

                <p>جمع هدایا</p>

            </div>
        </div>
    </div>

</div>

<div class="row g-4">

    <div class="col-lg-6">

        <div class="main-card p-4">

            <div class="section-title mb-3">
                <i class="fa-solid fa-trophy"></i>
                بهترین فروشنده ها
            </div>

            <table class="table">

                <thead>
                    <tr>
                        <th>فروشنده</th>
                        <th>ثبت</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td>احمدی</td>
                        <td>850</td>
                    </tr>

                    <tr>
                        <td>رضایی</td>
                        <td>720</td>
                    </tr>
                </tbody>

            </table>

        </div>

    </div>

    <div class="col-lg-6">

        <div class="main-card p-4">

            <div class="section-title mb-3">
                <i class="fa-solid fa-users"></i>
                بیشترین ثبت کننده گارانتی
            </div>

            <table class="table">

                <thead>
                    <tr>
                        <th>کاربر</th>
                        <th>تعداد</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td>admin</td>
                        <td>1250</td>
                    </tr>

                    <tr>
                        <td>user1</td>
                        <td>1080</td>
                    </tr>
                </tbody>

            </table>

        </div>

    </div>

</div>