
@model List<GolpaMotorFinal.Models.ViewModels.UserManagement.UserListItemViewModel>
@using GolpaMotorFinal.Helpers


<div class="main-card">
    <div class="p-4">

        <div class="section-title mb-3">
            <i class="fa fa-table text-primary"></i>
            لیست کاربران
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">

                <thead class="table-dark">
                    <tr>
                        <th>عکس</th>
                        <th>نام</th>
                        <th>موبایل</th>
                        <th>شغل</th>
                        <th>استان</th>
                        <th>شهر</th>
                        <th>کارت ثبت شده</th>
                        <th>امتیاز کسب شده</th>
                        <th>جزئیات</th>
                        <th>ویرایش</th>
                        <th>حذف</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <img src="@ImageHelper.FixUser(item.ProfileImageUrl)"
                                         style="width:50px;height:50px;object-fit:cover;border-radius:6px;" />
                                </td>
                                <td>@item.FullName</td>
                                <td>@item.PhoneNumber</td>
                                <td>@item.RoleName</td>
                                <td>@item.Province</td>
                                <td>@item.City</td>
                                <td>@item.TotalRegisteredCards</td>
                                <td>@item.TotalEarnedPoints</td>
                                <td>
                                    <button class="btn btn-sm btnDetails" data-id="@item.UserID">
                                        <i class="fa fa-eye text-secondary"></i>
                                    </button>
                                </td>

                                <td>
                                    <button class="btn btn-sm btnEdit" data-id="@item.UserID">
                                        <i class="fa fa-pen text-warning"></i>
                                    </button>
                                </td>

                                <td>
                                    <button class="btn btn-sm btnDelete" data-id="@item.UserID">
                                        <i class="fa fa-trash text-danger"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="13" class="text-center text-muted">
                                هیچ کاربری یافت نشد
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

    </div>
</div>

