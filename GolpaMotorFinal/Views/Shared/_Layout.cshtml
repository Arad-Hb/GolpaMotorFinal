<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - گلپا موتور</title>
    <link href="~/lib/bootstrap-5.3.8-dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/fonts/fontawesome-free-6.7.2-web/css/fontawesome.min.css" rel="stylesheet" />
    <link href="~/fonts/fontawesome-free-6.7.2-web/css/all.min.css" rel="stylesheet" />
    <link href="~/fonts/vazirmatn-master/vazirmatn-font-face.css" rel="stylesheet" />
    <link href="~/css/Layout.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/sweetalert2/sweetalert2.min.css">
    @RenderSection("Styles", required: false)

</head>
<body>
    <nav class="navbar navbar-expand-lg bg-white shadow-sm">
        <div class="container">
            <a asp-controller="Home" asp-action="Index" class="logo-wrapper">
                <img src="~/images/pics/logo.png" alt="گلپا موتور" class="logo-img">
            </a>
            <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#nav">
                <i class="fa-solid fa-bars"></i>
            </button>
            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a asp-controller="Home" asp-action="Index" class="nav-link"> خانه </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Product" asp-action="Index" class="nav-link"> محصولات </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="WarrantyManagement" asp-action="Index" class="nav-link"> ثبت کارت گارانتی </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link"> تماس با ما </a>
                    </li>
                </ul>
                <div class="search-box">
                    <input class="form-control" placeholder="جستجوی قطعه خودرو..." />
                    <button class="btn btn-primary">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>
                </div>
                <div class="auth-buttons me-5">
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </div>
    </nav>

    @if (TempData["SuccessMessage"] != null)
    {
       <div class="container mt-3">
            <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                <i class="fa-solid fa-circle-check me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div> 
    }
    <main>
        @RenderBody()
    </main>
    <footer class="footer">
        <div class="container text-center">
            <h5>Golpa Motor</h5>
            <p>© تمامی حقوق محفوظ است</p>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap-5.3.8-dist/js/bootstrap.bundle.js"></script>
    <script src="~/lib/bootstrap-5.3.8-dist/js/bootstrap.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/lib/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/js/site.js"></script>
    @await Component.InvokeAsync("Allert")
    @RenderSection("Scripts", required: false)
    
</body>

</html>